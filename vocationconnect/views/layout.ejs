<!doctype html>
<html>
  <head>
    <title><%= title %> - <%= siteData.siteName %></title>
    <link rel="stylesheet" type="text/css" href="<%= BASE_URL %>/main.css" />
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
  </head>
  <body>
    <header>
      <div class="logo-section">
        <img src="<%= BASE_URL %>/images/logo.svg" alt="<%= siteData.siteName %> Logo" class="logo" />
        <h1><%= siteData.siteName %></h1>
      </div>
      
      <nav>
        <a href="<%= BASE_URL %>/">Home</a>
        <a href="<%= BASE_URL %>/about">About</a>
        
        <% if (!session || !session.userId) { %>
          <a href="<%= BASE_URL %>/users/register">Register</a>
          <a href="<%= BASE_URL %>/users/login">Login</a>
        <% } else { %>
          <a href="<%= BASE_URL %>/dashboard">Dashboard</a>
          <a href="<%= BASE_URL %>/alumni/browse">Browse Alumni</a>
          <a href="<%= BASE_URL %>/connections/my">Connections</a>
          <a href="<%= BASE_URL %>/messages/my">Messages</a>
          <a href="<%= BASE_URL %>/notifications" id="notifications-link">Notifications</a>
          <a href="<%= BASE_URL %>/interviews/my">Interviews</a>
          <a href="<%= BASE_URL %>/users/profile">Profile</a>
          <a href="<%= BASE_URL %>/users/logout">Logout</a>
        <% } %>
      </nav>
      
      <% if (session && session.username) { %>
        <p>👤 <strong><%= session.username %></strong></p>
      <% } %>
    </header>

    <main>
      <%- body %>
    </main>

    <% if (session && session.userId) { %>
    <script>
      // Update notification count
      function updateNotificationCount() {
        fetch('<%= BASE_URL %>/notifications/unread-count')
          .then(response => response.json())
          .then(data => {
            const notificationLink = document.getElementById('notifications-link');
            if (notificationLink) {
              // Remove existing badge
              const existingBadge = notificationLink.querySelector('.notification-badge');
              if (existingBadge) {
                existingBadge.remove();
              }

              if (data.count > 0) {
                const badge = document.createElement('span');
                badge.className = 'notification-badge';
                badge.textContent = data.count > 99 ? '99+' : data.count;
                badge.style.cssText = `
                  background-color: #dc3545;
                  color: white;
                  border-radius: 50%;
                  padding: 2px 6px;
                  font-size: 0.8em;
                  margin-left: 5px;
                  vertical-align: top;
                `;
                notificationLink.appendChild(badge);
              }
            }
          })
          .catch(error => console.error('Error fetching notification count:', error));
      }

      // Update notification count on page load
      document.addEventListener('DOMContentLoaded', updateNotificationCount);

      // Update notification count every 30 seconds
      setInterval(updateNotificationCount, 30000);
    </script>
    <% } %>
  </body>
</html>
