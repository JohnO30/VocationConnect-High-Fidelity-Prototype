<div class="content-wrapper">
  <h2>🔍 Search Results</h2>

  <div class="card" style="margin-bottom: 1.5rem; background-color: var(--bg-light);">
    <div style="display: flex; gap: 1.5rem; flex-wrap: wrap;">
      <% if (keyword) { %>
        <div>
          <p style="margin: 0; font-size: 0.85rem; color: var(--text-light);">KEYWORD</p>
          <p style="margin: 0.25rem 0 0 0; font-weight: 600;">"<%= keyword %>"</p>
        </div>
      <% } %>
      <% if (industry && industry !== 'all') { %>
        <div>
          <p style="margin: 0; font-size: 0.85rem; color: var(--text-light);">INDUSTRY</p>
          <p style="margin: 0.25rem 0 0 0; font-weight: 600;"><%= industry %></p>
        </div>
      <% } %>
    </div>
  </div>

  <% if (alumni && alumni.length > 0) { %>
    <div class="success" style="margin-bottom: 1.5rem; background-color: #E6F7ED; border-left: 4px solid var(--success-color);">
      ✓ Found <strong><%= alumni.length %></strong> <%= alumni.length === 1 ? 'alumnus' : 'alumni' %> matching your criteria
    </div>
    
    <div class="grid">
      <% alumni.forEach(function(alum) { %>
        <div class="card alumni-card" style="padding: 1.5rem; text-align: center;">
          <div style="font-size: 3rem; margin-bottom: 1rem;">👤</div>
          
          <h3 style="margin: 0 0 0.5rem 0; font-size: 1.1rem;"><%= alum.first_name %> <%= alum.last_name %></h3>
          
          <p class="company" style="margin: 0.5rem 0; font-weight: 600; color: var(--primary-color);"><%= alum.company || 'Company not specified' %></p>
          <p class="job-title" style="margin: 0 0 0.75rem 0; color: var(--text-gray); font-size: 0.9rem;"><%= alum.job_title || 'Job title not specified' %></p>
          
          <div style="display: flex; flex-direction: column; gap: 0.5rem; margin-bottom: 1rem; font-size: 0.85rem; color: var(--text-gray);">
            <div>📊 <strong><%= alum.industry || 'N/A' %></strong> Industry</div>
            <div>⏳ <strong><%= alum.years_experience || 0 %></strong> years experience</div>
          </div>
          
          <% if (alum.available_for_mock) { %>
            <span class="badge badge-success" style="display: block; margin-bottom: 1rem; justify-content: center;">✓ Available for Interviews</span>
          <% } %>
          
          <div class="card-footer" style="border-top: 1px solid var(--border-light); margin: 0 -1.5rem -1.5rem; padding: 1rem; padding-top: 1rem; display: grid; gap: 0.5rem;">
            <a href="<%= BASE_URL %>/alumni/<%= alum.id %>" class="btn btn-primary" style="display: block; text-align: center;">View Full Profile</a>
            <% if (session.userType === 'student') { %>
              <form action="<%= BASE_URL %>/connections/request" method="POST" style="margin:0;">
                <input type="hidden" name="alumni_id" value="<%= alum.id %>">
                <input type="hidden" name="message" value="Hi <%= alum.first_name %>, I would love to connect and learn more about your experience.">
                <input type="submit" value="Request Connection" class="btn" style="display: block; text-align: center;">
              </form>
            <% } %>
          </div>
        </div>
      <% }); %>
    </div>
  <% } else { %>
    <div class="card" style="text-align: center; padding: 3rem;">
      <p style="font-size: 1.1rem; color: var(--text-gray); margin-top: 0;">🔍 No alumni found matching your criteria.</p>
      <p style="color: var(--text-gray); margin-bottom: 1.5rem;">Try adjusting your search keywords or industry filters.</p>
      <a href="<%= BASE_URL %>/alumni/search" class="btn btn-secondary" style="margin-right: 0.5rem;">New Search</a>
      <a href="<%= BASE_URL %>/alumni/browse" class="btn">Browse All Alumni</a>
    </div>
  <% } %>

  <% if (alumni && alumni.length > 0) { %>
    <div style="text-align: center; margin-top: 2rem; padding: 1rem; background-color: var(--bg-light); border-radius: 8px;">
      <p style="margin: 0; color: var(--text-gray);">
        Want to refine your search? <a href="<%= BASE_URL %>/alumni/search" style="color: var(--primary-color); text-decoration: none; font-weight: 600;">Try a new search</a>
      </p>
    </div>
  <% } %>
</div>
