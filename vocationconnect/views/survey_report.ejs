<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <style>
    :root {
      --primary-color: #0077B5;
      --primary-dark: #005885;
      --success-color: #27AE60;
      --warning-color: #F39C12;
      --danger-color: #E74C3C;
      --text-dark: #2C3E50;
      --text-light: #7F8C8D;
      --border-light: #ECF0F1;
      --bg-light: #F8F9FA;
    }

    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
      color: var(--text-dark);
      background-color: var(--bg-light);
      line-height: 1.6;
    }

    .report-container {
      max-width: 1000px;
      margin: 2rem auto;
      padding: 0 1rem;
    }

    .report-header {
      background: linear-gradient(135deg, var(--primary-color), var(--primary-dark));
      color: white;
      padding: 2rem;
      border-radius: 8px;
      margin-bottom: 2rem;
      text-align: center;
    }

    .report-header h1 {
      font-size: 2rem;
      margin-bottom: 0.5rem;
    }

    .score-badge {
      display: inline-block;
      font-size: 3rem;
      font-weight: bold;
      margin: 1rem 0;
      background: rgba(255, 255, 255, 0.2);
      padding: 1rem 1.5rem;
      border-radius: 8px;
    }

    .score-label {
      font-size: 1rem;
      opacity: 0.9;
    }

    .grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 1.5rem;
      margin-bottom: 2rem;
    }

    .card {
      background: white;
      border-radius: 8px;
      padding: 1.5rem;
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
      transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

    .card:hover {
      transform: translateY(-4px);
      box-shadow: 0 4px 16px rgba(0, 0, 0, 0.15);
    }

    .card-title {
      font-size: 1.1rem;
      font-weight: 600;
      color: var(--primary-color);
      margin-bottom: 1rem;
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }

    .card-icon {
      font-size: 1.5rem;
    }

    .card-content {
      color: var(--text-light);
    }

    .list-item {
      padding: 0.5rem 0;
      border-bottom: 1px solid var(--border-light);
    }

    .list-item:last-child {
      border-bottom: none;
    }

    .list-item-title {
      font-weight: 600;
      color: var(--text-dark);
    }

    .list-item-subtitle {
      font-size: 0.9rem;
      color: var(--text-light);
    }

    .summary-box {
      background: linear-gradient(135deg, rgba(0, 119, 181, 0.05), rgba(39, 174, 96, 0.05));
      border-left: 4px solid var(--primary-color);
      padding: 1.5rem;
      border-radius: 4px;
      margin-bottom: 2rem;
    }

    .summary-box h2 {
      color: var(--primary-color);
      margin-bottom: 1rem;
      font-size: 1.2rem;
    }

    .summary-box p {
      line-height: 1.8;
      color: var(--text-dark);
    }

    .section-header {
      font-size: 1.3rem;
      font-weight: 600;
      color: var(--primary-color);
      margin-top: 2rem;
      margin-bottom: 1.5rem;
      padding-bottom: 0.75rem;
      border-bottom: 2px solid var(--border-light);
    }

    .skill-gap {
      background: white;
      padding: 1rem;
      border-radius: 4px;
      margin-bottom: 1rem;
      border-left: 3px solid var(--warning-color);
    }

    .skill-name {
      font-weight: 600;
      color: var(--text-dark);
      margin-bottom: 0.5rem;
    }

    .skill-meta {
      display: flex;
      gap: 1rem;
      font-size: 0.9rem;
      color: var(--text-light);
      margin-bottom: 0.5rem;
    }

    .skill-resources {
      display: flex;
      gap: 0.5rem;
      flex-wrap: wrap;
      margin-top: 0.75rem;
    }

    .resource-badge {
      background-color: var(--bg-light);
      color: var(--text-dark);
      padding: 0.25rem 0.75rem;
      border-radius: 12px;
      font-size: 0.85rem;
    }

    .mentor-card {
      background: white;
      padding: 1.5rem;
      border-radius: 8px;
      margin-bottom: 1rem;
      border-left: 3px solid var(--success-color);
    }

    .mentor-header {
      display: flex;
      justify-content: space-between;
      align-items: start;
      margin-bottom: 0.75rem;
    }

    .mentor-name {
      font-weight: 600;
      font-size: 1.05rem;
      color: var(--primary-color);
    }

    .match-score {
      background-color: var(--success-color);
      color: white;
      padding: 0.25rem 0.75rem;
      border-radius: 12px;
      font-size: 0.85rem;
      font-weight: 600;
    }

    .mentor-details {
      display: flex;
      flex-direction: column;
      gap: 0.25rem;
      color: var(--text-light);
      font-size: 0.9rem;
      margin-bottom: 1rem;
    }

    .mentor-action {
      display: inline-block;
      padding: 0.5rem 1rem;
      background-color: var(--primary-color);
      color: white;
      border: none;
      border-radius: 4px;
      cursor: pointer;
      text-decoration: none;
      font-size: 0.9rem;
      transition: background-color 0.2s ease;
    }

    .mentor-action:hover {
      background-color: var(--primary-dark);
    }

    .recommendation {
      background: white;
      padding: 1.5rem;
      border-radius: 8px;
      margin-bottom: 1rem;
      border-top: 3px solid var(--primary-color);
    }

    .recommendation-title {
      font-weight: 600;
      color: var(--text-dark);
      margin-bottom: 0.5rem;
      font-size: 1rem;
    }

    .recommendation-content {
      color: var(--text-light);
      line-height: 1.7;
    }

    .action-list {
      list-style: none;
      padding: 0;
    }

    .action-list li {
      padding: 0.5rem 0;
      padding-left: 1.5rem;
      position: relative;
    }

    .action-list li:before {
      content: "→";
      position: absolute;
      left: 0;
      color: var(--primary-color);
      font-weight: bold;
    }

    .report-actions {
      display: flex;
      gap: 1rem;
      margin-top: 2rem;
      justify-content: center;
      flex-wrap: wrap;
    }

    .btn {
      padding: 0.75rem 1.5rem;
      border: none;
      border-radius: 4px;
      cursor: pointer;
      font-weight: 600;
      transition: all 0.2s ease;
      text-decoration: none;
      display: inline-block;
    }

    .btn-primary {
      background-color: var(--primary-color);
      color: white;
    }

    .btn-primary:hover {
      background-color: var(--primary-dark);
      transform: translateY(-2px);
      box-shadow: 0 4px 12px rgba(0, 119, 181, 0.3);
    }

    .btn-secondary {
      background-color: var(--bg-light);
      color: var(--text-dark);
      border: 1px solid var(--border-light);
    }

    .btn-secondary:hover {
      background-color: var(--border-light);
    }

    .empty-state {
      text-align: center;
      padding: 2rem;
      background: white;
      border-radius: 8px;
      color: var(--text-light);
    }

    .empty-state-icon {
      font-size: 3rem;
      margin-bottom: 1rem;
    }

    @media (max-width: 768px) {
      .report-header h1 {
        font-size: 1.5rem;
      }

      .score-badge {
        font-size: 2rem;
        padding: 0.75rem 1rem;
      }

      .grid {
        grid-template-columns: 1fr;
      }

      .report-actions {
        flex-direction: column;
      }

      .btn {
        width: 100%;
        text-align: center;
      }
    }
  </style>
</head>
<body>
  <div class="report-container">
    <!-- Report Header -->
    <div class="report-header">
      <h1>📊 Your Opportunity Report</h1>
      <div class="score-badge">
        <span id="scoreValue"><%= report.totalScore %></span><span>/100</span>
      </div>
      <div class="score-label">Career Readiness Score</div>
      <small>Generated: <%= new Date(report.generatedAt).toLocaleDateString() %></small>
    </div>

    <!-- Summary -->
    <div class="summary-box">
      <h2>📝 Your Assessment Summary</h2>
      <p><%= report.summary %></p>
    </div>

    <!-- Key Metrics -->
    <div class="grid">
      <div class="card">
        <div class="card-title">
          <span class="card-icon">🎯</span> Target Industries
        </div>
        <div class="card-content">
          <% report.topIndustries.forEach(industry => { %>
            <div class="list-item">
              <div class="list-item-title"><%= industry %></div>
            </div>
          <% }); %>
          <% if (report.topIndustries.length === 0) { %>
            <p>No specific industries selected</p>
          <% } %>
        </div>
      </div>

      <div class="card">
        <div class="card-title">
          <span class="card-icon">💼</span> Recommended Roles
        </div>
        <div class="card-content">
          <% report.topRoles.forEach(role => { %>
            <div class="list-item">
              <div class="list-item-title"><%= role %></div>
            </div>
          <% }); %>
          <% if (report.topRoles.length === 0) { %>
            <p>No roles recommended yet</p>
          <% } %>
        </div>
      </div>

      <div class="card">
        <div class="card-title">
          <span class="card-icon">👥</span> Mentor Opportunities
        </div>
        <div class="card-content">
          <div class="list-item">
            <div class="list-item-title"><%= mentors.length %></div>
            <div class="list-item-subtitle">Available mentors matched for you</div>
          </div>
          <div class="list-item">
            <div class="list-item-title"><%= report.interviewOpportunities %></div>
            <div class="list-item-subtitle">Mentors available for interviews</div>
          </div>
        </div>
      </div>

      <div class="card">
        <div class="card-title">
          <span class="card-icon">📚</span> Skills to Develop
        </div>
        <div class="card-content">
          <div class="list-item">
            <div class="list-item-title"><%= report.skillGaps.length %></div>
            <div class="list-item-subtitle">Key skills to focus on</div>
          </div>
        </div>
      </div>
    </div>

    <!-- Skill Gaps & Development -->
    <div class="section-header">📖 Skills to Develop</div>
    <div>
      <% if (report.skillGaps.length > 0) { %>
        <% report.skillGaps.forEach((gap, index) => { %>
          <div class="skill-gap">
            <div class="skill-name"><%= index + 1 %>. <%= gap.skill %></div>
            <div class="skill-meta">
              <span>📊 Proficiency: <strong><%= gap.proficiency_level %></strong></span>
              <span>⭐ Importance: <strong><%= gap.importance %>/10</strong></span>
            </div>
            <div class="skill-resources">
              <% if (gap.resources) { %>
                <% JSON.parse(gap.resources || '[]').forEach(resource => { %>
                  <span class="resource-badge">📌 <%= resource.type === 'online_course' ? '📚' : resource.type === 'practice' ? '💻' : '👤' %> <%= resource.platform %></span>
                <% }); %>
              <% } %>
            </div>
          </div>
        <% }); %>
      <% } else { %>
        <div class="empty-state">
          <div class="empty-state-icon">✨</div>
          <p>Great! You have strong skills. Focus on refining your specialization.</p>
        </div>
      <% } %>
    </div>

    <!-- Recommended Mentors -->
    <div class="section-header">👥 Your Matched Mentors</div>
    <div>
      <% if (mentors.length > 0) { %>
        <% mentors.forEach((mentor, index) => { %>
          <div class="mentor-card">
            <div class="mentor-header">
              <div>
                <div class="mentor-name"><%= mentor.first_name %> <%= mentor.last_name %></div>
                <div class="mentor-details">
                  <div>💼 <%= mentor.job_title %> at <%= mentor.company || 'N/A' %></div>
                  <div>🏢 <%= mentor.industry %> • 📅 <%= mentor.years_experience %> years experience</div>
                  <% if (mentor.available_for_mock) { %>
                    <div style="color: var(--success-color);">✓ Available for mock interviews</div>
                  <% } %>
                </div>
              </div>
              <div class="match-score"><%= mentor.matchScore %>% Match</div>
            </div>
            <a href="<%= BASE_URL %>/alumni/<%= mentor.id %>" class="mentor-action">View Profile & Connect</a>
          </div>
        <% }); %>
      <% } else { %>
        <div class="empty-state">
          <div class="empty-state-icon">🔍</div>
          <p>No mentors found matching your criteria yet. More alumni profiles are being added regularly!</p>
        </div>
      <% } %>
    </div>

    <!-- Career Recommendations -->
    <div class="section-header">🎯 Career Development Plan</div>
    <div>
      <% if (report.careerRecommendations && report.careerRecommendations.immediate) { %>
        
        <!-- Immediate Goals -->
        <div class="recommendation">
          <div class="recommendation-title">🚀 Immediate Goal (Next 6-12 months)</div>
          <div class="recommendation-content">
            <p><strong>Focus:</strong> <%= report.careerRecommendations.immediate.focus %></p>
            <p style="margin-top: 0.75rem;"><strong>Action Items:</strong></p>
            <ul class="action-list">
              <% report.careerRecommendations.immediate.actions.forEach(action => { %>
                <li><%= action %></li>
              <% }); %>
            </ul>
          </div>
        </div>

        <!-- Short-term Goals -->
        <div class="recommendation">
          <div class="recommendation-title">📈 Short-term Goal (1-2 years)</div>
          <div class="recommendation-content">
            <p><strong>Focus:</strong> <%= report.careerRecommendations.shortTerm.focus %></p>
            <p style="margin-top: 0.75rem;"><strong>Action Items:</strong></p>
            <ul class="action-list">
              <% report.careerRecommendations.shortTerm.actions.forEach(action => { %>
                <li><%= action %></li>
              <% }); %>
            </ul>
          </div>
        </div>

        <!-- Medium-term Goals -->
        <div class="recommendation">
          <div class="recommendation-title">🎓 Medium-term Goal (3-5 years)</div>
          <div class="recommendation-content">
            <p><strong>Focus:</strong> <%= report.careerRecommendations.mediumTerm.focus %></p>
            <p style="margin-top: 0.75rem;"><strong>Action Items:</strong></p>
            <ul class="action-list">
              <% report.careerRecommendations.mediumTerm.actions.forEach(action => { %>
                <li><%= action %></li>
              <% }); %>
            </ul>
          </div>
        </div>

        <!-- Key Milestones -->
        <div class="recommendation">
          <div class="recommendation-title">⭐ Key Milestones</div>
          <div class="recommendation-content">
            <ul class="action-list">
              <% report.careerRecommendations.keyMilestones.forEach(milestone => { %>
                <li><%= milestone %></li>
              <% }); %>
            </ul>
          </div>
        </div>

      <% } %>
    </div>

    <!-- Report Actions -->
    <div class="report-actions">
      <a href="<%= BASE_URL %>/survey/history" class="btn btn-secondary">📊 View All Reports</a>
      <a href="<%= BASE_URL %>/alumni/search" class="btn btn-primary">🔍 Search Alumni</a>
      <a href="<%= BASE_URL %>/survey/start" class="btn btn-secondary">📝 Retake Survey</a>
    </div>
  </div>

  <script>
    // Animate score counter
    window.addEventListener('load', () => {
      const scoreValue = document.getElementById('scoreValue');
      const finalScore = parseInt(scoreValue.textContent);
      let currentScore = 0;
      const increment = Math.ceil(finalScore / 20);

      const interval = setInterval(() => {
        if (currentScore < finalScore) {
          currentScore = Math.min(currentScore + increment, finalScore);
          scoreValue.textContent = currentScore;
        } else {
          clearInterval(interval);
        }
      }, 30);
    });
  </script>
</body>
</html>
