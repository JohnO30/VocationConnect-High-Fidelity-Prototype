<h2>Search Alumni</h2>

<form action="<%= BASE_URL %>/alumni/search" method="POST">
    <label for="keyword">Search by keyword:</label>
    <input type="text" id="keyword" name="keyword" placeholder="Name, company, job title, skills...">
    
    <label for="industry">Filter by industry:</label>
    <select id="industry" name="industry">
        <option value="all">All Industries</option>
        <option value="Technology">Technology</option>
        <option value="Finance">Finance</option>
        <option value="Healthcare">Healthcare</option>
        <option value="Education">Education</option>
        <option value="Consulting">Consulting</option>
        <option value="Other">Other</option>
    </select>
    
    <input type="submit" value="Search">
</form>

<p><a href="<%= BASE_URL %>/alumni/browse">Browse all alumni</a></p>
