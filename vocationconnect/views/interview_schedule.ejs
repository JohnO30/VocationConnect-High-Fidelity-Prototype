<div class="content-wrapper">
  <h2>Schedule Mock Interview</h2>

  <div class="card" style="margin-bottom: 2rem; padding: 2rem; text-align: center; background: linear-gradient(135deg, #E7F3FF, #F0F8FF);">
    <div style="font-size: 2rem; margin-bottom: 1rem;">📅</div>
    <h3 style="margin: 0 0 0.5rem 0; color: var(--primary-color);"><%= alumni.first_name %> <%= alumni.last_name %></h3>
    <p style="margin: 0; color: var(--primary-color); font-weight: 600;"><%= alumni.job_title %></p>
    <p style="margin: 0.5rem 0 0 0; color: var(--text-gray);"><%= alumni.company %></p>
  </div>

  <div class="card">
    <h3 style="margin-top: 0;">Schedule Your Interview</h3>

    <form action="<%= BASE_URL %>/interviews/schedule" method="POST">
      <input type="hidden" name="alumni_id" value="<%= alumni.id %>">
      
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; margin-bottom: 1.5rem;">
        <div style="grid-column: 1 / -1;">
          <label for="scheduled_date">📅 Select Date & Time:</label>
          <input type="datetime-local" id="scheduled_date" name="scheduled_date" required>
        </div>
        
        <div>
          <label for="duration_minutes">⏱️ Duration:</label>
          <select id="duration_minutes" name="duration_minutes">
            <option value="20">20 minutes</option>
            <option value="30" selected>30 minutes</option>
            <option value="45">45 minutes</option>
            <option value="60">60 minutes</option>
          </select>
        </div>
        
        <div>
          <label for="interview_type">🎯 Interview Type:</label>
          <select id="interview_type" name="interview_type">
            <option value="Technical Interview">Technical Interview</option>
            <option value="Behavioral Interview">Behavioral Interview</option>
            <option value="Case Interview">Case Interview</option>
            <option value="General Career Guidance">General Career Guidance</option>
          </select>
        </div>
      </div>
      
      <div style="margin-bottom: 2rem;">
        <label for="notes">💬 Notes / Special Requests (optional):</label>
        <textarea id="notes" name="notes" placeholder="Share any specific topics, concerns, or areas you'd like to focus on..."></textarea>
      </div>
      
      <button type="submit" class="btn" style="padding: 0.75rem 2rem; font-size: 1rem;">Schedule Interview</button>
    </form>
  </div>

  <div class="info" style="margin-top: 2rem;">
    <p style="margin: 0; font-size: 0.9rem;">
      ℹ️ <strong>Tip:</strong> Choose a time that works for both you and the interviewer. Send a specific message about what you'd like to focus on to make the most of your interview!
    </p>
  </div>
</div>
