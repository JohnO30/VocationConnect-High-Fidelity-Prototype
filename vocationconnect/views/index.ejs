<div class="content-wrapper">
  <% if (session && session.userId) { %>
    <div class="welcome-message" style="margin-bottom: 2rem;">
      <h2 style="margin-top: 0; margin-bottom: 0.5rem;">👋 Welcome back, <strong><%= session.username %></strong>!</h2>
      <p style="margin-bottom: 0; color: #003D7A;">Ready to connect with alumni and practice your interview skills?</p>
    </div>
    
    <div class="grid" style="margin-bottom: 2rem;">
      <a href="<%= BASE_URL %>/dashboard" class="card" style="text-decoration: none; text-align: center; display: flex; flex-direction: column; justify-content: center; cursor: pointer; transition: all 0.2s ease;">
        <div style="font-size: 2rem; margin-bottom: 0.75rem;">📊</div>
        <h4 style="margin: 0 0 0.5rem 0; color: var(--primary-color);">View Dashboard</h4>
        <p style="margin: 0; font-size: 0.9rem;">Access your personalized dashboard</p>
      </a>
      
      <a href="<%= BASE_URL %>/alumni/browse" class="card" style="text-decoration: none; text-align: center; display: flex; flex-direction: column; justify-content: center; cursor: pointer; transition: all 0.2s ease;">
        <div style="font-size: 2rem; margin-bottom: 0.75rem;">🔍</div>
        <h4 style="margin: 0 0 0.5rem 0; color: var(--primary-color);">Browse Alumni</h4>
        <p style="margin: 0; font-size: 0.9rem;">Find mentors in your field</p>
      </a>
    </div>
  <% } else { %>
    <div class="card" style="text-align: center; margin-bottom: 2rem; padding: 2rem;">
      <h1 style="color: var(--primary-color); margin-top: 0;">Welcome to VocationConnect</h1>
      <p style="font-size: 1.1rem; color: var(--text-gray); max-width: 600px; margin: 1rem auto;">
        🌟 Connect with alumni mentors, gain career guidance, and practice mock interviews with experienced professionals from your university.
      </p>
      
      <div style="display: flex; gap: 1rem; justify-content: center; margin-top: 1.5rem;">
        <a href="<%= BASE_URL %>/users/login" class="btn" style="padding: 0.75rem 2rem; font-size: 1rem;">Sign In</a>
        <a href="<%= BASE_URL %>/users/register" class="btn btn-secondary" style="padding: 0.75rem 2rem; font-size: 1rem;">Get Started</a>
      </div>
    </div>
  <% } %>

  <h2>💡 Why VocationConnect?</h2>
  <div class="grid" style="margin-bottom: 2rem;">
    <div class="card">
      <div style="font-size: 1.75rem; margin-bottom: 0.75rem;">👥</div>
      <h4>Alumni Network</h4>
      <p>Access a curated network of successful alumni ready to share their insights and mentor the next generation.</p>
    </div>
    
    <div class="card">
      <div style="font-size: 1.75rem; margin-bottom: 0.75rem;">🎤</div>
      <h4>Mock Interviews</h4>
      <p>Practice real-world interview scenarios with experienced professionals and receive constructive feedback.</p>
    </div>
    
    <div class="card">
      <div style="font-size: 1.75rem; margin-bottom: 0.75rem;">🚀</div>
      <h4>Career Growth</h4>
      <p>Get personalized career advice, industry insights, and job search strategies from your mentors.</p>
    </div>
    
    <div class="card">
      <div style="font-size: 1.75rem; margin-bottom: 0.75rem;">💼</div>
      <h4>Industry Focus</h4>
      <p>Connect with alumni from diverse industries including Tech, Finance, Healthcare, and more.</p>
    </div>
  </div>

  <h2>🎯 How It Works</h2>
  <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); gap: 2rem; margin-bottom: 2rem;">
    <div style="text-align: center;">
      <div style="background: linear-gradient(135deg, #0077B5, #0A66C2); color: white; width: 50px; height: 50px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 1.5rem; margin: 0 auto 1rem; font-weight: 700;">1</div>
      <h4>Create Profile</h4>
      <p style="font-size: 0.9rem;">Sign up and build your professional profile</p>
    </div>
    
    <div style="text-align: center;">
      <div style="background: linear-gradient(135deg, #0077B5, #0A66C2); color: white; width: 50px; height: 50px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 1.5rem; margin: 0 auto 1rem; font-weight: 700;">2</div>
      <h4>Browse & Connect</h4>
      <p style="font-size: 0.9rem;">Find alumni and send connection requests</p>
    </div>
    
    <div style="text-align: center;">
      <div style="background: linear-gradient(135deg, #0077B5, #0A66C2); color: white; width: 50px; height: 50px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 1.5rem; margin: 0 auto 1rem; font-weight: 700;">3</div>
      <h4>Schedule Interviews</h4>
      <p style="font-size: 0.9rem;">Book mock interview sessions</p>
    </div>
    
    <div style="text-align: center;">
      <div style="background: linear-gradient(135deg, #0077B5, #0A66C2); color: white; width: 50px; height: 50px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 1.5rem; margin: 0 auto 1rem; font-weight: 700;">4</div>
      <h4>Grow & Succeed</h4>
      <p style="font-size: 0.9rem;">Gain confidence and land your dream job</p>
    </div>
  </div>
</div>
