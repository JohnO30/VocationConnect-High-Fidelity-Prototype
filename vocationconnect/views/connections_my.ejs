<h2>My Connections</h2>

<% if (connections && connections.length > 0) { %>
  <div class="grid">
    <% connections.forEach(function(conn) { %>
      <div class="card">
        <h3>
          <% if (session.userType === 'student') { %>
            <%= conn.first_name %> <%= conn.last_name %>
          <% } else { %>
            <%= conn.first_name %> <%= conn.last_name %> (<%= conn.email %>)
          <% } %>
        </h3>
        
        <% if (session.userType === 'student' && conn.company) { %>
          <p><strong><%= conn.company %></strong></p>
          <p><%= conn.job_title %></p>
        <% } %>
        
        <p><strong>Status:</strong> <span class="interview-status status-<%= conn.status %>"><%= conn.status %></span></p>
        <p><strong>Requested:</strong> <%= new Date(conn.created_at).toLocaleDateString() %></p>
        
        <% if (conn.message) { %>
          <div class="info">
            <p><strong>Message:</strong> <%= conn.message %></p>
          </div>
        <% } %>
        
        <div class="card-footer">
          <% if (session.userType === 'alumni' && conn.status === 'pending') { %>
            <form action="<%= BASE_URL %>/connections/<%= conn.id %>/accept" method="POST" style="display:inline;">
              <input type="submit" value="Accept" class="btn btn-success">
            </form>
            <form action="<%= BASE_URL %>/connections/<%= conn.id %>/decline" method="POST" style="display:inline;">
              <input type="submit" value="Decline" class="btn btn-danger">
            </form>
          <% } %>
          
          <% if (session.userType === 'student' && conn.status === 'accepted') { %>
            <a href="<%= BASE_URL %>/alumni/<%= conn.alumni_id %>" class="btn">View Profile</a>
          <% } %>
        </div>
      </div>
    <% }); %>
  </div>
<% } else { %>
  <p>No connections found.</p>
  <% if (session.userType === 'student') { %>
    <a href="<%= BASE_URL %>/alumni/browse" class="btn">Browse Alumni to Connect</a>
  <% } %>
<% } %>
